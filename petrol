#include <stdio.h>

int tour(int petrol[], int distance[], int n) {
    int start = 0;
    int deficit = 0;
    int current_petrol = 0;
    
    for (int i = 0; i < n; i++) {
        current_petrol += petrol[i] - distance[i];
        if (current_petrol < 0) {
            deficit += current_petrol;
            start = i + 1;
            current_petrol = 0;
        }
    }
    
    return (current_petrol + deficit >= 0) ? start : -1;
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    
    int petrol[n];
    for (int i = 0; i < n; i++) {
        if (scanf("%d", &petrol[i]) != 1) return 0;
    }
    
    int distance[n];
    for (int i = 0; i < n; i++) {
        if (scanf("%d", &distance[i]) != 1) return 0;
    }
    
    int result = tour(petrol, distance, n);
    printf("%d\n", result);
    
    return 0;
}
