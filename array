#include <stdio.h>
#include <stdlib.h>

int search(int A[], int N, int key) {
    int low = 0;
    int high = N - 1;
    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (A[mid] == key) {
            return mid;
        }
        if (A[low] <= A[mid]) {
            if (key >= A[low] && key < A[mid]) {
                high = mid - 1; 
            } else {
                low = mid + 1;  
            }
        } 
        else {
            if (key > A[mid] && key <= A[high]) {
                low = mid + 1;  
            } else {
                high = mid - 1; 
            }
        }
    }
    return -1;
}
int main() {
    int N, key;
    printf("Enter the number of elements (N): ");
    if (scanf("%d", &N) != 1 || N <= 0) {
        printf("Invalid array size.\n");
        return 1;
    }
    int *A = (int *)malloc(N * sizeof(int));
    if (A == NULL) {
        printf("Memory allocation failed.\n");
        return 1;
    }
    printf("Enter %d distinct elements (e.g., 5 6 7 1 2 3): ", N);
    for (int i = 0; i < N; i++) {
        if (scanf("%d", &A[i]) != 1) {
            printf("Invalid input reading element at index %d.\n", i);
            free(A);
            return 1;
        }
    }
    printf("Enter the key element to find: ");
    if (scanf("%d", &key) != 1) {
        printf("Invalid key input.\n");
        free(A);
        return 1;
    }
    int result_index = search(A, N, key);
    printf("\n--- Result ---\n");
    if (result_index != -1) {
        printf("Element %d found at index: %d\n", key, result_index);
    } else {
        printf("Element %d not found in the array (Output: -1)\n", key);
    }
    free(A);
    return 0;
}
