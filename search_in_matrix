#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

int searchInMatrix(int N, int M, int **mat, int X) {
    int row = 0;
    int col = M - 1;
    while (row < N && col >= 0) {
        if (mat[row][col] == X) {
            return 1; 
        }
        else if (mat[row][col] > X) {
            col--; 
        }
        else {
            row++; 
        }
    }

    return 0; 
}

int main() {
    int N, M, X;

    if (scanf("%d %d", &N, &M) != 2) return 0;

    int **mat = (int **)malloc(N * sizeof(int *));
    for (int i = 0; i < N; i++) {
        mat[i] = (int *)malloc(M * sizeof(int));
    }

    for (int i = 0; i < N; i++) {
        for (int j = 0; j < M; j++) {
            if (scanf("%d", &mat[i][j]) != 1) return 0;
        }
    }

    
    if (scanf("%d", &X) != 1) return 0;

    int result = searchInMatrix(N, M, mat, X);
    printf("%d\n", result);

    for (int i = 0; i < N; i++) {
        free(mat[i]);
    }
    free(mat);

    return 0;
}
