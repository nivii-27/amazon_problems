#include <stdio.h>
#include <string.h>

int min(int a, int b, int c) {
    int m = a;
    if (b < m) m = b;
    if (c < m) m = c;
    return m;
}

int editDistance(char* s, char* t) {
    int m = strlen(s);
    int n = strlen(t);
    int dp[m + 1][n + 1];
    
    for (int i = 0; i <= m; i++) {
        dp[i][0] = i;
    }
    for (int j = 0; j <= n; j++) {
        dp[0][j] = j;
    }
    
    for (int i = 1; i <= m; i++) {
        for (int j = 1; j <= n; j++) {
            if (s[i - 1] == t[j - 1]) {
                dp[i][j] = dp[i - 1][j - 1];
            } else {
                dp[i][j] = 1 + min(
                    dp[i - 1][j],    
                    dp[i][j - 1],    
                    dp[i - 1][j - 1] 
                );
            }
        }
    }
    
    return dp[m][n];
}

int main() {
    char s[105];
    char t[105];
    
    if (scanf("%104s", s) != 1) return 0;
    if (scanf("%104s", t) != 1) return 0;
    
    int result = editDistance(s, t);
    printf("%d\n", result);
    
    return 0;
}

